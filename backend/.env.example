# ══════════════════════════════════════════════
# Q-School AI — Environment Variables Example
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào Git
# ══════════════════════════════════════════════

# App
APP_NAME="Q-School AI"
APP_VERSION="1.0.0"
DEBUG=true                           # false ở production

# CORS (phân cách bởi dấu phẩy)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ──────────────────────────────────────────────
# Database — PostgreSQL
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# ──────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/qschool"

# ──────────────────────────────────────────────
# Redis & Celery
# ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"   # Dùng DB khác để tránh conflict

# ──────────────────────────────────────────────
# JWT Security
# QUAN TRỌNG: Sinh SECRET_KEY thật bằng lệnh:
#   openssl rand -hex 32
# ──────────────────────────────────────────────
SECRET_KEY="CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────
# vLLM / AI Inference (self-hosted)
# ──────────────────────────────────────────────
VLLM_API_URL="http://localhost:8001/v1"
VLLM_API_KEY="dev_key_only"
VLLM_MODEL_NAME="Qwen/Qwen2.5-7B-Instruct"

# ──────────────────────────────────────────────
# Object Storage — Cloudflare R2 / MinIO / AWS S3
# Dùng MinIO ở local: docker run -p 9000:9000 minio/minio server /data
# ──────────────────────────────────────────────
S3_ENDPOINT_URL="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET_NAME="qschool-uploads"
S3_PUBLIC_URL="http://localhost:9000/qschool-uploads"

# ──────────────────────────────────────────────
# Rate Limiting (SaaS — số requests AI tối đa/ngày)
# ──────────────────────────────────────────────
FREE_PLAN_AI_REQUESTS_PER_DAY=10
PRO_PLAN_AI_REQUESTS_PER_DAY=200
