# ══════════════════════════════════════════════════════════
# Q-School AI — Environment Variables
# Copy file này thành .env và điền giá trị thực
# TUYỆT ĐỐI KHÔNG commit file .env lên Git
# ══════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
APP_NAME=Q-School AI
APP_VERSION=1.0.0
DEBUG=true
APP_ENV=development                    # development | staging | production

# CORS (phân cách bằng dấu phẩy)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────
# PostgreSQL Database
# ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qschool

# Async URL (dùng cho FastAPI runtime — container hostname: db)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/qschool

# ──────────────────────────────────────────────
# Redis & Celery
# ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ──────────────────────────────────────────────
# JWT Security
# Tạo SECRET_KEY bằng: openssl rand -hex 32
# ──────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────
# vLLM AI Inference (Self-hosted)
# Uncomment khi GPU server sẵn sàng
# ──────────────────────────────────────────────
# VLLM_API_URL=http://vllm:8000/v1
# VLLM_API_KEY=dev_key_only
# VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Embedding model (KHAC generation model — dung cho RAG / DocumentChunk)
# Dimension PHAI match Vector(1536) trong DB migration
# EMBEDDING_MODEL_NAME=Qwen/Qwen2.5-Embedding-1.5B
# EMBEDDING_API_URL=http://vllm:8000/v1

# ──────────────────────────────────────────────
# Object Storage (MinIO local / Cloudflare R2 production)
# ──────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=qschool-uploads
S3_PUBLIC_URL=http://localhost:9000/qschool-uploads

# ──────────────────────────────────────────────
# Rate Limiting (SaaS)
# ──────────────────────────────────────────────
FREE_PLAN_AI_REQUESTS_PER_DAY=10
PRO_PLAN_AI_REQUESTS_PER_DAY=200

# ──────────────────────────────────────────────
# Frontend
# ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
