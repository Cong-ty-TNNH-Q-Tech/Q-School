+import logging
+import aioboto3
+from botocore.config import Config
+from botocore.exceptions import ClientError
+from app.application.ports.outbound.storage_service import IStorageService
+from app.core.config import settings
+
+logger = logging.getLogger(__name__)
+
+class R2StorageAdapter(IStorageService):
+    """
+    Adapter cho Cloudflare R2 / MinIO sß╗¡ dß╗Ñng aioboto3.
+    """
+    def __init__(self):
+        self.session = aioboto3.Session()
+        self.endpoint_url = settings.S3_ENDPOINT_URL
+        self.access_key = settings.S3_ACCESS_KEY
+        self.secret_key = settings.S3_SECRET_KEY
+        self.bucket_name = settings.S3_BUCKET_NAME
+        self.public_url = settings.S3_PUBLIC_URL.rstrip('/')
+        # MinIO/R2 cß║ºn signature S3v4
+        self.boto_config = Config(signature_version='s3v4')
+        
+    def _get_client(self):
+        # Cloudflare R2 y├¬u cß║ºu region_name='auto', MinIO cß║ºn 'us-east-1' hoß║╖c region chuß║⌐n
+        region = 'auto' if 'cloudflarestorage' in (self.endpoint_url or "") else 'us-east-1'
+        return self.session.client(
+            's3',
+            endpoint_url=self.endpoint_url if self.endpoint_url else None,
+            aws_access_key_id=self.access_key,
+            aws_secret_access_key=self.secret_key,
+            region_name=region,
+            config=self.boto_config
+        )
+        
+    def _extract_key_from_url(self, file_url: str) -> str:
+        """
+        Tr├¡ch xuß║Ñt S3 object key tß╗½ file_url.
+        """
+        if file_url.startswith(f"{self.public_url}/"):
+            return file_url[len(self.public_url) + 1:]
+            
+        if file_url.startswith(f"s3://{self.bucket_name}/"):
+            return file_url.replace(f"s3://{self.bucket_name}/", "", 1)
+            
+        return file_url
+
+    async def upload(
+        self,
+        file_bytes: bytes,
+        filename: str,
+        content_type: str,
+        *,
+        is_public: bool = False,
+    ) -> str:
+        """
+        Upload file v├á trß║ú vß╗ü URL ─æß╗â l╞░u v├áo DB.
+        """
+        extra_args = {'ContentType': content_type}
+        
+        try:
+            async with self._get_client() as s3_client:
+                await s3_client.put_object(
+                    Bucket=self.bucket_name,
+                    Key=filename,
+                    Body=file_bytes,
+                    **extra_args
+                )
+                
+            if is_public:
+                return f"{self.public_url}/{filename}"
+            else:
+                return f"s3://{self.bucket_name}/{filename}"
+                
+        except ClientError as e:
+            logger.error(f"Lß╗ùi khi upload {filename} l├¬n Storage: {e}")
+            raise Exception(f"Storage upload error: {str(e)}")
+
+    async def delete(self, file_url: str) -> None:
+        """X├│a file khß╗Åi storage theo URL."""
+        key = self._extract_key_from_url(file_url)
+        try:
+            async with self._get_client() as s3_client:
+                await s3_client.delete_object(
+                    Bucket=self.bucket_name,
+                    Key=key
+                )
+        except ClientError as e:
+            logger.error(f"Lß╗ùi khi x├│a {key} khß╗Åi Storage: {e}")
+            raise Exception(f"Storage delete error: {str(e)}")
+
+    async def get_presigned_url(self, file_url: str, expires_in: int = 3600) -> str:
+        """
+        Tß║ío presigned URL tß║ím thß╗¥i cho private files.
+        """
+        if file_url.startswith(f"{self.public_url}/"):
+            return file_url
+            
+        key = self._extract_key_from_url(file_url)
+        try:
+            async with self._get_client() as s3_client:
+                url = await s3_client.generate_presigned_url(
+                    ClientMethod='get_object',
+                    Params={
+                        'Bucket': self.bucket_name,
+                        'Key': key
+                    },
+                    ExpiresIn=expires_in
+                )
+                return url
+        except ClientError as e:
+            logger.error(f"Lß╗ùi khi tß║ío presigned URL cho {key}: {e}")
+            raise Exception(f"Storage presign error: {str(e)}")
